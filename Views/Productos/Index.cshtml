@model IEnumerable<Proyecto.Models.Producto>
@inject Proyecto.Services.IUserSessionService UserSession

@{
    ViewData["Title"] = "Productos";
}

<style>
    :root{
        --tinta:#241F1B;
        --crema:#FBF4E8;
        --crema-2:#F1E6D2;
        --terracota:#C75D3D;
        --terracota-d:#9C3F26;
        --mostaza:#E0A845;
        --salvia:#6B7A4F;
        --linea:#E2D3B4;
    }

    .em-prod-page{ font-family:'Work Sans','Segoe UI',sans-serif; color:var(--tinta); }

    .em-filter{
        background:var(--crema-2);
        border:1px solid var(--linea);
        border-radius:14px;
        padding:1rem 1.3rem;
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:2rem;
        color:var(--tinta);
    }
    .em-filter strong{ color:var(--terracota-d); }
    .em-filter .btn{
        background:var(--terracota);
        border:none;
        color:#fff;
        border-radius:999px;
        font-weight:600;
        font-size:.85rem;
        padding:.4rem 1rem;
    }
    .em-filter .btn:hover{ background:var(--terracota-d); color:#fff; }

    .em-header{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:2.2rem;
        flex-wrap:wrap;
        gap:1rem;
    }
    .em-header h1{
        font-family:'Fraunces', Georgia, serif;
        font-weight:600;
        font-size:2rem;
        color:var(--tinta);
        margin:0;
        display:flex;
        align-items:center;
        gap:.6rem;
    }
    .em-header h1 i{ color:var(--terracota); }

    .em-btn-create{
        background:var(--terracota);
        border:none;
        color:#fff;
        border-radius:999px;
        font-weight:600;
        padding:.65rem 1.4rem;
        transition:background .18s ease, transform .18s ease;
    }
    .em-btn-create:hover{ background:var(--terracota-d); color:#fff; transform:translateY(-2px); }

    .em-empty{
        text-align:center;
        padding:4rem 1rem;
        background:var(--crema-2);
        border-radius:16px;
        border:1px dashed var(--linea);
    }
    .em-empty i{ color:var(--salvia); }
    .em-empty p{ color:#8a8174; }

    /* ===== CARD ===== */
    .em-card{
        height:100%;
        background:#fff;
        border:1px solid var(--linea);
        border-radius:16px;
        overflow:hidden;
        transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }
    .em-card:hover{
        transform:translateY(-5px);
        box-shadow:0 18px 32px -18px rgba(36,31,27,.28);
        border-color:var(--terracota);
    }
    .em-card-imgwrap{ display:block; position:relative; }
    .em-card-imgwrap img{ height:180px; width:100%; object-fit:cover; }
    .em-card-noimg{
        height:180px;
        display:flex;
        align-items:center;
        justify-content:center;
        background:var(--crema-2);
        color:var(--terracota-d);
    }

    .em-card-body{ padding:1.1rem 1.2rem 1.3rem; display:flex; flex-direction:column; }

    .em-card-title{
        font-family:'Fraunces', serif;
        font-weight:600;
        font-size:1.02rem;
        color:var(--tinta);
        line-height:1.3;
        margin:0;
    }

    .em-badge{
        font-size:.7rem;
        font-weight:700;
        padding:.25rem .6rem;
        border-radius:999px;
        white-space:nowrap;
    }
    .em-badge-ok{ background:#E7EEDC; color:var(--salvia); border:1px solid #cfdcb9; }
    .em-badge-low{ background:#FBE9CE; color:var(--terracota-d); border:1px solid #f1cf9c; }
    .em-badge-out{ background:#F4DCD3; color:#9C3F26; border:1px solid #e9bba9; }

    .em-card-desc{
        color:#7a7164;
        font-size:.86rem;
        margin:.5rem 0 .7rem;
        flex-grow:1;
        display:-webkit-box;
        -webkit-line-clamp:2;
        -webkit-box-orient:vertical;
        overflow:hidden;
    }

    .em-card-price{
        font-family:'Fraunces', serif;
        font-weight:700;
        font-size:1.3rem;
        color:var(--terracota-d);
        margin-bottom:.6rem;
    }

    .em-card-meta{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:.8rem;
        gap:.5rem;
    }
    .em-card-shop{
        color:#8a8174;
        font-size:.8rem;
        text-decoration:none;
    }
    .em-card-shop:hover{ color:var(--terracota-d); }
    .em-card-cat{
        background:var(--salvia);
        color:#fff;
        font-size:.72rem;
        font-weight:600;
        padding:.25rem .6rem;
        border-radius:999px;
        text-decoration:none;
        white-space:nowrap;
    }
    .em-card-cat:hover{ background:#56624a; color:#fff; }

    .em-status-active{ background:#E7EEDC; color:var(--salvia); }
    .em-status-inactive{ background:var(--crema-2); color:#8a8174; }
    .em-status{ font-size:.72rem; font-weight:600; border-radius:999px; padding:.25rem .6rem; }

    .em-actions{ display:flex; gap:.5rem; flex-wrap:wrap; }

    .em-btn-add{
        background:var(--salvia);
        border:none;
        color:#fff;
        border-radius:999px;
        font-weight:600;
        font-size:.85rem;
        transition:background .18s ease;
    }
    .em-btn-add:hover{ background:#56624a; color:#fff; }
    .em-btn-add.btn-outline-success{
        background:transparent;
        border:1.5px solid var(--salvia);
        color:var(--salvia);
    }

    .em-btn-icon{
        border-radius:999px;
        width:36px; height:36px;
        display:inline-flex; align-items:center; justify-content:center;
        border:1.5px solid var(--linea);
        color:var(--tinta);
        background:transparent;
        transition:background .18s ease, color .18s ease, border-color .18s ease;
    }
    .em-btn-icon:hover{ background:var(--tinta); color:var(--crema); border-color:var(--tinta); }
    .em-btn-icon.danger:hover{ background:var(--terracota-d); border-color:var(--terracota-d); }
</style>

<div class="em-prod-page">

    @if (ViewData["SelectedEmprendimientoNombre"] != null)
    {
        <div class="em-filter">
            <span class="m-0">
                <i class="bi bi-funnel-fill me-2"></i> Mostrando productos de: <strong>@ViewData["SelectedEmprendimientoNombre"]</strong>
            </span>
            <a asp-action="Index" class="btn">
                <i class="bi bi-x-circle me-1"></i> Quitar Filtro
            </a>
        </div>
    }
    else if (ViewData["SelectedCategoriaNombre"] != null)
    {
        <div class="em-filter">
            <span class="m-0">
                <i class="bi bi-tag-fill me-2"></i> Mostrando productos de la categoría: <strong>@ViewData["SelectedCategoriaNombre"]</strong>
            </span>
            <a asp-action="Index" class="btn">
                <i class="bi bi-x-circle me-1"></i> Quitar Filtro
            </a>
        </div>
    }

    <div class="em-header">
        <h1><i class="bi bi-box-seam"></i>Productos</h1>
        @if (UserSession.IsAdmin || UserSession.IsEntrepreneur)
        {
            <a asp-action="Create" class="em-btn-create">
                <i class="bi bi-plus-circle me-1"></i> Crear Nuevo Producto
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="em-empty">
            <i class="bi bi-box-seam" style="font-size: 4rem;"></i>
            <p class="mt-3 fs-5">No hay productos disponibles.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="em-card">

                        <!-- Imagen del producto -->
                        <a asp-action="Details" asp-route-id="@item.Id" class="em-card-imgwrap">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.Nombre"
                                     onerror="this.onerror=null; this.parentElement.innerHTML='<div class=\'em-card-noimg\'><i class=\'bi bi-box-seam\' style=\'font-size:3rem;\'></i></div>';" />
                            }
                            else
                            {
                                <div class="em-card-noimg">
                                    <i class="bi bi-box-seam" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </a>

                        <div class="em-card-body">
                            <!-- Nombre y badge stock -->
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h6 class="em-card-title">@item.Nombre</h6>
                                @if (item.Stock > 5)
                                {
                                    <span class="em-badge em-badge-ok ms-1">@item.Stock disp.</span>
                                }
                                else if (item.Stock > 0)
                                {
                                    <span class="em-badge em-badge-low ms-1">¡Solo @item.Stock!</span>
                                }
                                else
                                {
                                    <span class="em-badge em-badge-out ms-1">Sin stock</span>
                                }
                            </div>

                            <!-- Descripción -->
                            <p class="em-card-desc">
                                @(string.IsNullOrEmpty(item.Descripcion) ? "Sin descripción." : item.Descripcion)
                            </p>

                            <!-- Precio -->
                            <div class="em-card-price">$@item.Precio.ToString("F2")</div>

                            <!-- Emprendimiento y Categoría -->
                            <div class="em-card-meta">
                                <a asp-controller="Productos" asp-action="Index" asp-route-emprendimientoId="@item.EmprendimientoId"
                                   class="em-card-shop">
                                    <i class="bi bi-shop me-1"></i>@item.Emprendimiento?.Nombre
                                </a>
                                <a asp-controller="Productos" asp-action="Index" asp-route-categoriaId="@item.CategoriaId"
                                   class="em-card-cat">
                                    @item.Categoria?.Nombre
                                </a>
                            </div>

                            @if (UserSession.IsAdmin || UserSession.IsEntrepreneur)
                            {
                                <div class="mb-2">
                                    @if (item.Activo)
                                    {
                                        <span class="em-status em-status-active">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="em-status em-status-inactive">Inactivo</span>
                                    }
                                </div>
                            }

                            <!-- Acciones -->
                            <div class="em-actions">
                                @if (UserSession.CanShop && item.Stock > 0)
                                {
                                    <form asp-controller="Carrito" asp-action="Add" method="post" class="d-inline ajax-cart-form flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productoId" value="@item.Id" />
                                        <input type="hidden" name="cantidad" value="1" />
                                        <button type="submit" class="btn btn-sm em-btn-add w-100 d-inline-flex align-items-center justify-content-center btn-add-cart">
                                            <i class="bi bi-cart-plus me-1"></i> Agregar
                                        </button>
                                    </form>
                                }
                                <a asp-action="Details" asp-route-id="@item.Id" class="em-btn-icon" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (UserSession.IsAdmin || (UserSession.IsEntrepreneur && item.Emprendimiento?.UsuarioId == UserSession.GetCurrentUserId()))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="em-btn-icon" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="em-btn-icon danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".ajax-cart-form").forEach(function (form) {
                form.addEventListener("submit", function (e) {
                    e.preventDefault();

                    var formData = new FormData(form);
                    var submitBtn = form.querySelector(".btn-add-cart");
                    var originalHtml = submitBtn.innerHTML;

                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';

                    fetch(form.action, {
                        method: "POST",
                        body: formData,
                        headers: {
                            "X-Requested-With": "XMLHttpRequest",
                            "Accept": "application/json"
                        }
                    })
                    .then(response => {
                        if (!response.ok) throw new Error("Error");
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            var badge = document.querySelector(".navbar .badge");
                            if (badge) {
                                badge.textContent = data.cartCount;
                                badge.classList.remove("d-none");
                            } else {
                                var cartLink = document.querySelector('a[href="/Carrito"]');
                                if (cartLink) {
                                    cartLink.innerHTML += ' <span class="badge bg-danger rounded-pill ms-1">' + data.cartCount + '</span>';
                                }
                            }

                            submitBtn.className = submitBtn.className.replace("em-btn-add", "em-btn-add btn-outline-success");
                            submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> ¡Listo!';

                            setTimeout(function () {
                                submitBtn.disabled = false;
                                submitBtn.className = submitBtn.className.replace(" btn-outline-success", "");
                                submitBtn.innerHTML = originalHtml;
                            }, 1500);
                        } else {
                            alert("No se pudo agregar al carrito.");
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalHtml;
                        }
                    })
                    .catch(error => {
                        console.error(error);
                        alert("Error al agregar al carrito.");
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalHtml;
                    });
                });
            });
        });
    </script>
}
