@model Proyecto.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 text-dark m-0"><i class="bi bi-box-seam me-2 text-primary"></i>Nuevo Producto</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Información del Producto</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                        <input asp-for="Nombre" class="form-control form-control-lg" placeholder="Nombre del producto" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Describe el producto..."></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="Precio" class="form-label fw-semibold">Precio <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Precio" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Stock" class="form-label fw-semibold">Stock <span class="text-danger">*</span></label>
                            <input asp-for="Stock" class="form-control" placeholder="0" />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImagenUrl" class="form-label fw-semibold">
                            <i class="bi bi-image me-1 text-primary"></i>URL de Imagen
                        </label>
                        <input asp-for="ImagenUrl" class="form-control" id="imagenUrlInput"
                               placeholder="https://ejemplo.com/imagen.jpg"
                               oninput="previewImage(this.value)" />
                        <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
                        <div class="form-text">URL de imagen del producto (opcional).</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="EmprendimientoId" class="form-label fw-semibold">Emprendimiento <span class="text-danger">*</span></label>
                            <select asp-for="EmprendimientoId" class="form-select" asp-items="ViewBag.EmprendimientoId">
                                <option value="">-- Selecciona --</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label asp-for="CategoriaId" class="form-label fw-semibold">Categoría <span class="text-danger">*</span></label>
                            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId">
                                <option value="">-- Selecciona --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="Activo" role="switch" id="activoSwitch" checked />
                            <label class="form-check-label fw-semibold" for="activoSwitch">Producto activo</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i> Crear Producto
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header py-3">
                <h5 class="mb-0 text-secondary"><i class="bi bi-eye me-2"></i>Vista Previa</h5>
            </div>
            <div class="card-body text-center p-4">
                <div id="imagePlaceholder" class="d-flex flex-column align-items-center justify-content-center bg-light rounded" style="height: 220px;">
                    <i class="bi bi-box-seam text-secondary" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-2 mb-0">Vista previa del producto</p>
                </div>
                <img id="imagePreview" src="" alt="Vista previa" class="img-fluid rounded shadow-sm d-none" style="max-height: 220px; object-fit: cover; width: 100%;" />
                <p class="text-muted small mt-2 mb-0">La imagen aparecerá en la lista de productos</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(url) {
            var preview = document.getElementById('imagePreview');
            var placeholder = document.getElementById('imagePlaceholder');
            if (url && url.trim() !== '') {
                preview.src = url;
                preview.classList.remove('d-none');
                placeholder.classList.add('d-none');
                preview.onerror = function () {
                    preview.classList.add('d-none');
                    placeholder.classList.remove('d-none');
                };
            } else {
                preview.classList.add('d-none');
                placeholder.classList.remove('d-none');
            }
        }
    </script>
}
