@{
    ViewData["Title"] = "Inicio";
}

<style>
    :root{
        --tinta:#241F1B;
        --crema:#FBF4E8;
        --crema-2:#F1E6D2;
        --terracota:#C75D3D;
        --terracota-d:#9C3F26;
        --mostaza:#E0A845;
        --salvia:#6B7A4F;
        --linea:#E2D3B4;
    }

    .em-page{ font-family:'Work Sans', 'Segoe UI', sans-serif; color:var(--tinta); overflow-x:hidden; }

    /* ===== HERO ===== */
    .em-hero{
        position:relative;
        display:grid;
        grid-template-columns:1.05fr .95fr;
        gap:2.5rem;
        align-items:center;
        background:var(--tinta);
        border-radius:22px;
        padding:3.5rem 3rem;
        color:var(--crema);
        overflow:hidden;
    }
    .em-hero::before{
        content:"";
        position:absolute;
        inset:0;
        background:
            radial-gradient(circle at 12% 18%, rgba(199,93,61,.35), transparent 45%),
            radial-gradient(circle at 85% 80%, rgba(224,168,69,.25), transparent 50%);
        pointer-events:none;
    }

    .em-hero-text{ position:relative; z-index:2; }

    .em-eyebrow{
        display:inline-flex;
        align-items:center;
        gap:.55rem;
        font-size:.74rem;
        font-weight:700;
        letter-spacing:.2em;
        text-transform:uppercase;
        color:var(--mostaza);
        margin-bottom:1.2rem;
    }
    .em-eyebrow::before{ content:"●"; font-size:.55rem; }

    .em-title{
        font-family:'Fraunces', Georgia, serif;
        font-weight:600;
        font-size:clamp(2.3rem, 4.2vw, 3.4rem);
        line-height:1.05;
        letter-spacing:-.01em;
        margin-bottom:1.1rem;
    }
    .em-title span{ color:var(--terracota); font-style:italic; }

    .em-lead{
        font-size:1.08rem;
        line-height:1.7;
        color:#E9DFCE;
        max-width:460px;
        margin-bottom:2rem;
    }

    .em-actions{ display:flex; gap:.85rem; flex-wrap:wrap; margin-bottom:2.2rem; }

    .em-btn{
        font-weight:600;
        font-size:.96rem;
        padding:.85rem 1.7rem;
        border-radius:999px;
        text-decoration:none;
        transition:transform .18s ease, background .18s ease, color .18s ease, border-color .18s ease;
        display:inline-flex;
        align-items:center;
    }
    .em-btn-primary{ background:var(--terracota); color:#fff; }
    .em-btn-primary:hover{ background:var(--mostaza); color:var(--tinta); transform:translateY(-2px); }
    .em-btn-outline{ border:1.5px solid #C9BBA0; color:var(--crema); }
    .em-btn-outline:hover{ border-color:var(--crema); background:rgba(255,255,255,.08); transform:translateY(-2px); }

    .em-stats{ display:flex; gap:1.8rem; border-top:1px solid rgba(255,255,255,.15); padding-top:1.3rem; }
    .em-stat-num{ font-family:'Fraunces', serif; font-size:1.5rem; font-weight:600; color:var(--mostaza); display:block; }
    .em-stat-label{ font-size:.78rem; color:#C9BBA0; }

    /* ===== COLLAGE ===== */
    .em-collage{ position:relative; height:380px; z-index:2; }
    .em-collage img{
        position:absolute;
        object-fit:cover;
        border-radius:14px;
        box-shadow:0 22px 40px -16px rgba(0,0,0,.55);
        border:5px solid var(--crema);
    }
    .em-ph-1{ width:58%; height:62%; top:0; left:6%; transform:rotate(-6deg); z-index:3; }
    .em-ph-2{ width:46%; height:48%; top:6%; right:0; transform:rotate(7deg); z-index:2; }
    .em-ph-3{ width:42%; height:42%; bottom:0; left:18%; transform:rotate(4deg); z-index:4; }
    .em-collage-tag{
        position:absolute;
        bottom:8%; right:4%;
        background:var(--mostaza);
        color:var(--tinta);
        font-weight:700;
        font-size:.78rem;
        padding:.55rem 1rem;
        border-radius:999px;
        z-index:5;
        box-shadow:0 10px 22px -10px rgba(0,0,0,.5);
        transform:rotate(-4deg);
    }

    /* ===== SECTION HEADER ===== */
    .em-section{ padding:4rem 0 1rem; }
    .em-section-head{ display:flex; justify-content:space-between; align-items:flex-end; gap:1.5rem; margin-bottom:2.4rem; flex-wrap:wrap; }
    .em-section-label{ font-size:.76rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--salvia); margin-bottom:.4rem; }
    .em-section-title{ font-family:'Fraunces', serif; font-weight:600; font-size:1.9rem; margin:0; max-width:480px; }
    .em-section-note{ font-size:.95rem; color:#7a7164; max-width:280px; text-align:right; }

    /* ===== ROLE ROWS (en vez de cards iguales) ===== */
    .em-roles{ display:flex; flex-direction:column; border-top:1px solid var(--linea); }
    .em-role{
        display:grid;
        grid-template-columns:90px 1fr 220px;
        align-items:center;
        gap:1.5rem;
        padding:1.9rem .5rem;
        border-bottom:1px solid var(--linea);
        transition:background .2s ease;
    }
    .em-role:hover{ background:var(--crema); }
    .em-role-icon{
        width:60px; height:60px;
        border-radius:50%;
        display:flex; align-items:center; justify-content:center;
        font-size:1.5rem;
        background:var(--crema-2);
        border:1.5px dashed var(--terracota);
        color:var(--terracota-d);
    }
    .em-role-title{ font-family:'Fraunces', serif; font-weight:600; font-size:1.25rem; margin-bottom:.3rem; }
    .em-role-text{ color:#6b645a; font-size:.96rem; line-height:1.5; max-width:520px; }
    .em-role-action{ text-align:right; }
    .em-role-action a{
        font-weight:600;
        font-size:.88rem;
        color:var(--terracota-d);
        text-decoration:none;
        border-bottom:1.5px solid var(--terracota);
        padding-bottom:2px;
    }
    .em-role-action a:hover{ color:var(--tinta); border-color:var(--mostaza); }

    @@media (max-width: 768px){
        .em-hero{ grid-template-columns:1fr; padding:2.4rem 1.5rem; }
        .em-collage{ height:300px; }
        .em-role{ grid-template-columns:50px 1fr; }
        .em-role-action{ display:none; }
        .em-section-head{ flex-direction:column; align-items:flex-start; }
        .em-section-note{ text-align:left; }
    }
</style>

<div class="em-page">

    <div class="em-hero">
        <div class="em-hero-text">
            <span class="em-eyebrow">Comunidad de emprendedores locales</span>
            <h1 class="em-title">Emprende<span>Market</span></h1>
            <p class="em-lead">Un marketplace para clientes y emprendedores. Explora productos, administra emprendimientos y gestiona pedidos en una plataforma lista para crecer.</p>
            <div class="em-actions">
                <a class="em-btn em-btn-primary" asp-controller="Productos" asp-action="Index">Explorar productos</a>
                <a class="em-btn em-btn-outline" asp-controller="Emprendimientos" asp-action="Index">Ver emprendimientos</a>
            </div>
            <div class="em-stats">
                <div>
                    <span class="em-stat-num">100%</span>
                    <span class="em-stat-label">Hecho a mano</span>
                </div>
                <div>
                    <span class="em-stat-num">+1</span>
                    <span class="em-stat-label">Plataforma, todo el flujo</span>
                </div>
                <div>
                    <span class="em-stat-num">24/7</span>
                    <span class="em-stat-label">Catálogo disponible</span>
                </div>
            </div>
        </div>

        <div class="em-collage">
            <img class="em-ph-1" src="https://i.pinimg.com/736x/10/56/e5/1056e58d4214a00a1547167e2605b45e.jpg" alt="Saco de lana artesanal">
            <img class="em-ph-2" src="https://i.pinimg.com/1200x/06/e2/ee/06e2ee729543168e9d1d694af3e7d7d8.jpg" alt="Jarrón rústico">
            <img class="em-ph-3" src="https://i.pinimg.com/736x/de/91/79/de91797e1faf8f96f68b419f852f4b25.jpg" alt="Torta de chocolate">
            <span class="em-collage-tag">Hecho por emprendedores ✦</span>
        </div>
    </div>

    <div class="em-section">
        <div class="em-section-head">
            <div>
                <p class="em-section-label">Cómo funciona</p>
                <h2 class="em-section-title">Una plataforma, tres formas de participar</h2>
            </div>
            <p class="em-section-note">Cada perfil tiene su propio espacio dentro de EmprendeMarket, sin pasos de más.</p>
        </div>

        <div class="em-roles">
            <div class="em-role">
                <div class="em-role-icon">🛒</div>
                <div>
                    <h5 class="em-role-title">Para clientes</h5>
                    <p class="em-role-text">Busca productos, filtra por categoría y realiza pedidos con un flujo claro y sencillo.</p>
                </div>
                <div class="em-role-action"><a asp-controller="Productos" asp-action="Index">Ver catálogo →</a></div>
            </div>
            <div class="em-role">
                <div class="em-role-icon">🧺</div>
                <div>
                    <h5 class="em-role-title">Para emprendedores</h5>
                    <p class="em-role-text">Registra tu emprendimiento, agrega productos y mantén tu catálogo actualizado.</p>
                </div>
                <div class="em-role-action"><a asp-controller="Emprendimientos" asp-action="Index">Ver emprendimientos →</a></div>
            </div>
            <div class="em-role">
                <div class="em-role-icon">⚙️</div>
                <div>
                    <h5 class="em-role-title">Administración</h5>
                    <p class="em-role-text">Gestiona usuarios, pedidos y datos del marketplace desde una interfaz limpia y profesional.</p>
                </div>
                <div class="em-role-action"></div>
            </div>
        </div>
    </div>

</div>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,500&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
