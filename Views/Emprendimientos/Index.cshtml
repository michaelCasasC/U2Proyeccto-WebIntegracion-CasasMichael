@model IEnumerable<Proyecto.Models.Emprendimiento>
@inject Proyecto.Services.IUserSessionService UserSession

@{
    ViewData["Title"] = "Emprendimientos";
}

<style>
    :root{
        --tinta:#241F1B;
        --crema:#FBF4E8;
        --crema-2:#F1E6D2;
        --terracota:#C75D3D;
        --terracota-d:#9C3F26;
        --mostaza:#E0A845;
        --salvia:#6B7A4F;
        --linea:#E2D3B4;
    }

    .em-emp-page{ font-family:'Work Sans','Segoe UI',sans-serif; color:var(--tinta); }

    .em-header{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:2.2rem;
        flex-wrap:wrap;
        gap:1rem;
    }
    .em-header h1{
        font-family:'Fraunces', Georgia, serif;
        font-weight:600;
        font-size:2rem;
        color:var(--tinta);
        margin:0;
        display:flex;
        align-items:center;
        gap:.6rem;
    }
    .em-header h1 i{ color:var(--terracota); }

    .em-btn-create{
        background:var(--terracota);
        border:none;
        color:#fff;
        border-radius:999px;
        font-weight:600;
        padding:.65rem 1.4rem;
        transition:background .18s ease, transform .18s ease;
    }
    .em-btn-create:hover{ background:var(--terracota-d); color:#fff; transform:translateY(-2px); }

    .em-empty{
        text-align:center;
        padding:4rem 1rem;
        background:var(--crema-2);
        border-radius:16px;
        border:1px dashed var(--linea);
    }
    .em-empty i{ color:var(--salvia); }
    .em-empty p{ color:#8a8174; }

    /* ===== CARD ===== */
    .em-card{
        height:100%;
        background:#fff;
        border:1px solid var(--linea);
        border-radius:16px;
        overflow:hidden;
        transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }
    .em-card:hover{
        transform:translateY(-5px);
        box-shadow:0 18px 32px -18px rgba(36,31,27,.28);
        border-color:var(--terracota);
    }
    .em-card-imgwrap{ display:block; position:relative; }
    .em-card-imgwrap img{ height:180px; width:100%; object-fit:cover; }
    .em-card-noimg{
        height:180px;
        display:flex;
        align-items:center;
        justify-content:center;
        background:var(--crema-2);
        color:var(--terracota-d);
    }

    .em-card-body{ padding:1.1rem 1.2rem 1.3rem; display:flex; flex-direction:column; }

    .em-card-title a{
        font-family:'Fraunces', serif;
        font-weight:600;
        font-size:1.15rem;
        color:var(--tinta);
        text-decoration:none;
    }
    .em-card-title a:hover{ color:var(--terracota-d); }

    .em-status{ font-size:.72rem; font-weight:600; border-radius:999px; padding:.25rem .65rem; white-space:nowrap; }
    .em-status-active{ background:#E7EEDC; color:var(--salvia); border:1px solid #cfdcb9; }
    .em-status-inactive{ background:var(--crema-2); color:#8a8174; border:1px solid var(--linea); }

    .em-card-desc{
        color:#7a7164;
        font-size:.88rem;
        margin:.6rem 0 0;
        flex-grow:1;
        display:-webkit-box;
        -webkit-line-clamp:2;
        -webkit-box-orient:vertical;
        overflow:hidden;
    }

    .em-card-meta{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin:.9rem 0 1rem;
        padding-top:.8rem;
        border-top:1px dashed var(--linea);
        gap:.5rem;
    }
    .em-card-meta small{ color:#9a9082; font-size:.78rem; }

    .em-actions{ display:flex; gap:.5rem; flex-wrap:wrap; }

    .em-btn-details{
        flex-grow:1;
        background:var(--salvia);
        border:none;
        color:#fff;
        border-radius:999px;
        font-weight:600;
        font-size:.85rem;
        padding:.5rem 1rem;
        text-align:center;
        text-decoration:none;
        transition:background .18s ease;
    }
    .em-btn-details:hover{ background:#56624a; color:#fff; }

    .em-btn-icon{
        border-radius:999px;
        width:36px; height:36px;
        display:inline-flex; align-items:center; justify-content:center;
        border:1.5px solid var(--linea);
        color:var(--tinta);
        background:transparent;
        transition:background .18s ease, color .18s ease, border-color .18s ease;
    }
    .em-btn-icon:hover{ background:var(--tinta); color:var(--crema); border-color:var(--tinta); }
    .em-btn-icon.danger:hover{ background:var(--terracota-d); border-color:var(--terracota-d); }
</style>

<div class="em-emp-page">

    <div class="em-header">
        <h1><i class="bi bi-shop"></i>Emprendimientos</h1>
        @if (UserSession.IsAdmin || UserSession.IsEntrepreneur)
        {
            <a asp-action="Create" class="em-btn-create">
                <i class="bi bi-plus-circle me-1"></i> Crear Nuevo Emprendimiento
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="em-empty">
            <i class="bi bi-shop" style="font-size: 4rem;"></i>
            <p class="mt-3 fs-5">No hay emprendimientos registrados aún.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="em-card">

                        <!-- Imagen del emprendimiento -->
                        <a asp-controller="Productos" asp-action="Index" asp-route-emprendimientoId="@item.Id" class="em-card-imgwrap">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.Nombre"
                                     onerror="this.onerror=null; this.src=''; this.parentElement.innerHTML='<div class=\'em-card-noimg\'><i class=\'bi bi-shop\' style=\'font-size:3rem;\'></i></div>';" />
                            }
                            else
                            {
                                <div class="em-card-noimg">
                                    <i class="bi bi-shop" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </a>

                        <div class="em-card-body">
                            <!-- Nombre y estado -->
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h5 class="em-card-title mb-0">
                                    <a asp-controller="Productos" asp-action="Index" asp-route-emprendimientoId="@item.Id">
                                        @item.Nombre
                                    </a>
                                </h5>
                                @if (item.Activo)
                                {
                                    <span class="em-status em-status-active ms-2">Activo</span>
                                }
                                else
                                {
                                    <span class="em-status em-status-inactive ms-2">Inactivo</span>
                                }
                            </div>

                            <!-- Descripción -->
                            <p class="em-card-desc">
                                @(string.IsNullOrEmpty(item.Descripcion) ? "Sin descripción." : item.Descripcion)
                            </p>

                            <!-- Dueño y fecha -->
                            <div class="em-card-meta">
                                <small><i class="bi bi-person me-1"></i>@item.Usuario?.Email</small>
                                <small>@item.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</small>
                            </div>

                            <!-- Acciones -->
                            <div class="em-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="em-btn-details">
                                    <i class="bi bi-eye me-1"></i>Detalles
                                </a>
                                @if (UserSession.IsAdmin || (UserSession.IsEntrepreneur && item.UsuarioId == UserSession.GetCurrentUserId()))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="em-btn-icon" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="em-btn-icon danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
