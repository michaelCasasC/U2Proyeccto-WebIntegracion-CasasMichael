<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmprendeMarket</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,500&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Proyecto.styles.css" asp-append-version="true" />

    <style>
        :root{
            --tinta:#241F1B;
            --crema:#FBF4E8;
            --crema-2:#F1E6D2;
            --terracota:#C75D3D;
            --terracota-d:#9C3F26;
            --mostaza:#E0A845;
            --salvia:#6B7A4F;
            --linea:#E2D3B4;
        }

        html, body{
            background:var(--crema);
            font-family:'Work Sans', 'Segoe UI', sans-serif;
            color:var(--tinta);
        }

        /* ===== NAVBAR ===== */
        .navbar{
            background:var(--tinta) !important;
            padding-top:.85rem;
            padding-bottom:.85rem;
            border-bottom:3px solid var(--terracota);
        }

        .navbar-brand{
            font-family:'Fraunces', Georgia, serif;
            font-weight:600;
            font-size:1.35rem;
            letter-spacing:-.01em;
            color:var(--crema) !important;
            display:flex;
            align-items:center;
        }
        .navbar-brand i{ color:var(--mostaza); }

        .navbar-nav .nav-link{
            color:#E9DFCE !important;
            font-weight:500;
            font-size:.95rem;
            padding:.5rem 1rem !important;
            border-radius:999px;
            transition:background .18s ease, color .18s ease;
        }
        .navbar-nav .nav-link:hover{
            background:rgba(255,255,255,.08);
            color:#fff !important;
        }

        .navbar-nav .nav-link.fw-semibold{
            background:var(--terracota);
            color:#fff !important;
        }
        .navbar-nav .nav-link.fw-semibold:hover{
            background:var(--terracota-d);
        }

        .navbar-text{
            color:#E9DFCE !important;
            font-size:.92rem;
        }
        .navbar-text i{ color:var(--mostaza); }

        .navbar .badge.bg-danger{
            background:var(--mostaza) !important;
            color:var(--tinta) !important;
            font-weight:700;
        }

        .navbar-toggler{
            border-color:rgba(255,255,255,.25);
        }
        .navbar-toggler-icon{
            filter:invert(1) grayscale(1) brightness(1.6);
        }

        /* Botón "Crear cuenta" destacado */
        .navbar-nav.ms-auto .nav-item:last-child .nav-link{
            border:1.5px solid var(--mostaza);
            color:var(--mostaza) !important;
        }
        .navbar-nav.ms-auto .nav-item:last-child .nav-link:hover{
            background:var(--mostaza);
            color:var(--tinta) !important;
        }

        /* ===== CONTENIDO ===== */
        main{
            min-height:55vh;
        }

        /* ===== FOOTER ===== */
        .footer{
            background:var(--tinta) !important;
            border-top:none !important;
            color:#C9BBA0 !important;
            padding:1.6rem 0 !important;
            font-size:.9rem;
        }
        .footer span:first-child{
            font-family:'Fraunces', serif;
            font-weight:600;
            color:var(--crema);
            letter-spacing:.02em;
        }
        .footer span:last-child{
            color:var(--mostaza);
            font-weight:500;
        }
    </style>
</head>
<body>
    @inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
    @inject Proyecto.Services.IUserSessionService UserSession
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-1"></i> EmprendeMarket
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Productos" asp-action="Index">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categorias" asp-action="Index">Categorías</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Emprendimientos" asp-action="Index">Emprendimientos</a>
                        </li>
                        @if (UserSession.IsAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                            </li>
                        }
                        @if (UserSession.IsLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Pedidos" asp-action="Index">Pedidos</a>
                            </li>
                        }
                        @if (UserSession.CanShop)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-semibold" asp-controller="Carrito" asp-action="Index">
                                    <i class="bi bi-cart3 me-1"></i> Carrito
                                    @{
                                        int cartCount = 0;
                                        var cartJson = HttpContextAccessor.HttpContext?.Session?.GetString("ShoppingCart");
                                        if (!string.IsNullOrEmpty(cartJson))
                                        {
                                            try
                                            {
                                                var cartDict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<int, int>>(cartJson);
                                                if (cartDict != null)
                                                {
                                                    cartCount = cartDict.Values.Sum();
                                                }
                                            }
                                            catch {}
                                        }
                                    }
                                    @if (cartCount > 0)
                                    {
                                        <span class="badge bg-danger rounded-pill ms-1">@cartCount</span>
                                    }
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        @if (UserSession.IsLoggedIn)
                        {
                            var currentUser = UserSession.GetCurrentUser();
                            <li class="nav-item">
                                <span class="navbar-text text-white me-3">
                                    <i class="bi bi-person-circle me-1"></i> Hola, @currentUser?.Nombre
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> Salir
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Crear cuenta</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container py-4">
        <main role="main" class="pb-3 mb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3 bg-light mt-20">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 EmprendeMarket</span> 
            <span>Listo para crecer con tu negocio</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
